#
# ImmortalWrt x86_64 .config 种子文件
# 本地 WSL 编译与 GitHub 云编译共用此文件。
# 此文件用于 make defconfig 时作为参考，未被显式选中的项会按依赖自动补全。
# 平台：x86_64 软路由 / 虚拟机 / 物理机
# 分支基线：immortalwrt openwrt-24.10
#

# ====== 目标平台 ======
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_generic=y

# ====== 镜像格式与分区 ======
# combined 镜像 = 内核 + rootfs 一体，适合 dd / physdiskwriter 刷写
# efi 后缀 = UEFI 引导（现代软路由/虚拟机推荐）；不带 efi 则为传统 BIOS
CONFIG_TARGET_ROOTFS_TARGZ=y
CONFIG_TARGET_ROOTFS_CPIOGZ=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_IMAGES_GZIP=y

# 根分区大小（MB）。设为 8192 = 8GB，给代理内核、日志、配置留足空间
# 本机配置：N6005 / 32GB 内存 / 250GB NVMe SSD（不使用 Docker，全部原生插件）
# 250GB 空间充裕，8GB 根分区绰绰有余；如不够可改 16384
CONFIG_TARGET_ROOTFS_PARTSIZE=8192
# 内核分区大小（MB），x86 一般保持默认即可
CONFIG_TARGET_KERNEL_PARTSIZE=64

# ====== 镜像产物（勾选后会生成对应文件）======
CONFIG_TARGET_IMAGES_PAD=y
# 生成 vmdk：给 VMware / ESXi 用
# 注意：immortalwrt 默认会生成 combined 的 img，vmdk 由目标自动产出
# 下面这些是常见可选镜像格式，按需保留
# CONFIG_GRUB_IMAGES is not set
# CONFIG_VMDK_IMAGES is not set
CONFIG_TARGET_KERNEL_PARTSIZE=64

# ====== 主题 ======
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-bootstrap 内置默认，无需显式声明

# ====== LuCI 基础（中文 + 管理）======
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y

# ====== 系统管理工具 ======
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_busybox=y

# ====== 网络时间 / DDNS / UPnP ======
CONFIG_PACKAGE_luci-app-ntpc=y
CONFIG_PACKAGE_luci-i18n-ntpc-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ====== 科学上网 / 代理（全部原生编译进固件，不依赖 Docker）======
# 注意：相关插件在内地使用的合规性请自行评估。
# 已内置：PassWall / PassWall2 / SSR-Plus / OpenClash / HomeProxy
# 新增：Nikki / FullCombo Shark! / luci-app-xray / NeKoBox / Daed / v2rayA

# PassWall 全家桶
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
# PassWall 常用内核
CONFIG_PACKAGE_passwall-iptables=y
CONFIG_PACKAGE_passwall-nftables=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_v2ray-core=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y

# HomeProxy（基于 sing-box，现代协议支持好）
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_homeproxy=y

# SSR Plus+
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_shadowsocks-rust-ssredir=y
CONFIG_PACKAGE_shadowsocks-rust-ssserver=y

# OpenClash（通过外部 feed vernesong/OpenClash 引入）
CONFIG_PACKAGE_luci-app-openclash=y

# Nikki（Mihomo/Clash.Meta 透明代理，OpenClash 轻量平替，第三方 feed）
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y
# Mihomo 内核（Nikki / FullCombo Shark! 共用）
CONFIG_PACKAGE_mihomo=y

# FullCombo Shark!（灵活定制 Mihomo，第三方 feed fcshark-org）
CONFIG_PACKAGE_luci-app-fchomo=y

# luci-app-xray（全功能 Xray 客户端，第三方 feed yichya）
CONFIG_PACKAGE_luci-app-xray=y

# NeKoBox（基于 sing-box/Mihomo，面向家庭用户，第三方 feed Thaolga）
CONFIG_PACKAGE_luci-app-nekobox=y
CONFIG_PACKAGE_luci-i18n-nekobox-zh-cn=y

# Daed（基于 eBPF 的代理平台，第三方 feed QiuSimons）
CONFIG_PACKAGE_luci-app-daed=y
CONFIG_PACKAGE_daed=y

# v2rayA（官方源已收录）
CONFIG_PACKAGE_v2raya=y
CONFIG_PACKAGE_luci-app-v2raya=y
CONFIG_PACKAGE_luci-i18n-v2raya-zh-cn=y
# 注意：相关插件在内地使用的合规性请自行评估。
# PassWall 全家桶
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
# PassWall 常用内核
CONFIG_PACKAGE_passwall-iptables=y
CONFIG_PACKAGE_passwall-nftables=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_v2ray-core=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y

# HomeProxy（基于 sing-box，现代协议支持好）
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_homeproxy=y

# SSR Plus+
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_shadowsocks-rust-ssredir=y
CONFIG_PACKAGE_shadowsocks-rust-ssserver=y

# OpenClash（通过外部 feed vernesong/OpenClash 引入，见 scripts/feeds.conf.custom）
CONFIG_PACKAGE_luci-app-openclash=y

# ====== 去广告 ======
CONFIG_PACKAGE_luci-app-adblock=y
CONFIG_PACKAGE_luci-i18n-adblock-zh-cn=y
CONFIG_PACKAGE_adblock=y

# AdGuard Home（DNS 层去广告，更强大）
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# ====== DNS 解析优化（防污染 / 加速 / 解锁）======
# mosdns：国内外 DNS 分流防污染（LuCI 来自第三方 feed sbwml）
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-i18n-mosdns-zh-cn=y
# smartdns：DNS 测速，自动返回最快节点 IP
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
# https-dns-proxy：加密 DNS（DoH/DoT）
CONFIG_PACKAGE_https-dns-proxy=y
CONFIG_PACKAGE_luci-app-https-dns-proxy=y
CONFIG_PACKAGE_luci-i18n-https-dns-proxy-zh-cn=y
# 网易云音乐解锁（unblockneteasemusic）
CONFIG_PACKAGE_unblockneteasemusic=y
CONFIG_PACKAGE_luci-app-unblockneteasemusic=y
CONFIG_PACKAGE_luci-i18n-unblockneteasemusic-zh-cn=y

# ====== 远程访问 / 异地组网 ======
# Tailscale：零配置异地组网
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y
# ZeroTier：虚拟局域网组网
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
# WireGuard：高性能 VPN（内核模块 + 工具 + LuCI 协议）
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-i18n-proto-wireguard-zh-cn=y
# frp 内网穿透（客户端 frpc + 服务端 frps）
CONFIG_PACKAGE_frpc=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-i18n-frpc-zh-cn=y
CONFIG_PACKAGE_frps=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_luci-i18n-frps-zh-cn=y

# ====== 网络管理 / 流量控制 ======
# mwan3：多 WAN 负载均衡 / 故障切换
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
# nlbwmon：按设备流量统计
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y
# SQM QoS：带宽整形
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
# 上网时间控制 / 家长控制
CONFIG_PACKAGE_luci-app-timecontrol=y
CONFIG_PACKAGE_luci-i18n-timecontrol-zh-cn=y

# ====== 监控 / 通知推送 ======
# Netdata：实时系统资源监控（CPU/内存/网络图表）
CONFIG_PACKAGE_netdata=y
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE_luci-i18n-netdata-zh-cn=y
# collectd：长期统计（流量、负载历史曲线）
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-uptime=y
CONFIG_PACKAGE_collectd-mod-ping=y
CONFIG_PACKAGE_collectd-mod-iptables=y
CONFIG_PACKAGE_collectd-mod-conntrack=y
CONFIG_PACKAGE_collectd-mod-df=y
# 微信/TG 推送（serverchan 与 wechatpush 二选一，来自第三方 feed）
CONFIG_PACKAGE_luci-app-serverchan=y
CONFIG_PACKAGE_luci-i18n-serverchan-zh-cn=y
CONFIG_PACKAGE_luci-app-wechatpush=y
CONFIG_PACKAGE_luci-i18n-wechatpush-zh-cn=y
# WoL 网络唤醒
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_wakeonlan=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y

# ====== NAS / 网络存储 ======
# Samba（Windows 文件共享）
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-admin=y
# 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-nfs=y
CONFIG_PACKAGE_kmod-fs-nfs-common=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fstab=y
CONFIG_PACKAGE_luci-app-fstab=y
CONFIG_PACKAGE_luci-i18n-fstab-zh-cn=y
# NFS
CONFIG_PACKAGE_nfs-kernel-server=y
CONFIG_PACKAGE_nfs-kernel-server-utils=y
# 磁盘/挂载工具
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools=y

# ====== 其它实用插件 ======
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_luci-app-flowoffload=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-access-control=y
CONFIG_PACKAGE_luci-i18n-access-control-zh-cn=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-filetransfer=y

# ====== 驱动 / 内核模块（针对本机：4 × Intel I226-V 2.5GbE，纯有线）======
# Intel I226-V 用 igc 驱动（内核 5.x 起内置），PCI ID 8086:125c
CONFIG_PACKAGE_kmod-igc=y
# 兼容其它常见 Intel 网卡（虚拟机迁移/换机时备用）
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-iavf=y
# Realtek 备用（换机型/USB 网卡可能用到）
CONFIG_PACKAGE_kmod-r8168=y
CONFIG_PACKAGE_kmod-r8125=y
# NVMe 存储（本机用 NVMe SSD 启动）
CONFIG_PACKAGE_kmod-nvme=y
# Intel 核显（如 CPU 带核显，留作硬件转码备用）
CONFIG_PACKAGE_kmod-i915=y
# 温度传感器（小主机常见）
CONFIG_PACKAGE_kmod-hwmon-core=y
CONFIG_PACKAGE_kmod-hwmon-coretemp=y
# USB 存储（U 盘 / 移动硬盘备用）
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb3=y

# 注：本机为纯有线，未勾选无线驱动（iwlwifi/ath*），减小体积。
# 如未来加装 Wi-Fi 网卡，在此添加对应 kmod-* 即可。

# ====== PPPoE 拨号（本机 WAN 用 PPPoE 拨号，光猫桥接模式）======
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_luci-proto-ppp=y
# IPv6 拨号（国内宽带 IPv6 普及）
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# ====== 网络加速 / BBR ======
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y

# ====== 硬件加密（N6005 支持 AES-NI，大幅提升代理/VPN 加密吞吐）======
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-aes-x86_64=y
CONFIG_PACKAGE_kmod-crypto-gcm=y
CONFIG_PACKAGE_kmod-crypto-ghash=y
CONFIG_PACKAGE_kmod-crypto-crc32c=y
CONFIG_PACKAGE_kmod-crypto-user=y
CONFIG_PACKAGE_kmod-cryptodev=y
CONFIG_PACKAGE_libopenssl=y
# kpp/shortcut-fe 原生转发加速（N6005 转发性能不错，按需开启）
CONFIG_PACKAGE_luci-app-sfe=y

# ====== 压缩 / 下载工具 ======
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_zip=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ca-bundle=y

# ====== 国际化 / 字体 ======
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ====== 编译优化（可选）======
# 去除不必要的镜像类型，加快编译、减小体积
# CONFIG_GRUB_IMAGES is not set
# CONFIG_ISO_IMAGES is not set
# CONFIG_VDI_IMAGES is not set
